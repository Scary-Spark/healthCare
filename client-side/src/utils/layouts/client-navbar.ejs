<!-- 
  CLIENT NAVBAR - Authenticated Header for Patient Portal
  Features: Logo, Emergency, Notifications, Profile Dropdown, Search
  Static frontend - backend integration later
-->
<header class="client-navbar">
  <!-- DEBUG: Show raw user data -->
  <% console.log("🎨 EJS RENDER: user =", user); %>

  <div class="navbar-container">
    <!-- Logo -->
    <a href="/dashboard" class="navbar-logo">
      <div class="logo-icon">
        <i class="fa-solid fa-heart-pulse"></i>
      </div>
      <div class="logo-text">
        <span class="logo-name">NovaLife</span>
        <span class="logo-tagline">Patient Portal</span>
      </div>
    </a>

    <!-- Search Bar (Desktop) -->
    <div class="navbar-search">
      <form class="search-form">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input
          type="search"
          placeholder="Search doctors, records..."
          class="search-input"
          aria-label="Search"
        />
      </form>
    </div>

    <!-- Right Actions -->
    <div class="navbar-actions">
      <!-- Emergency Button -->
      <a href="/emergency" class="btn-emergency" title="Emergency Assistance">
        <i class="fa-solid fa-truck-medical"></i>
        <span class="emergency-text">Emergency</span>
      </a>

      <!-- Notification Bell -->
      <div class="nav-notification">
        <button
          class="notification-btn"
          id="notificationToggle"
          aria-label="Notifications"
          aria-expanded="false"
        >
          <i class="fa-regular fa-bell"></i>
          <span class="notification-badge" id="notificationCount">3</span>
        </button>
        <div class="notification-dropdown" id="notificationDropdown" hidden>
          <div class="dropdown-header">
            <h4>Notifications</h4>
            <button class="mark-read" id="markAllRead">Mark all read</button>
          </div>
          <div class="notification-list">
            <div class="notification-item unread">
              <i class="fa-solid fa-calendar-check notif-icon"></i>
              <div class="notif-content">
                <p><strong>Appointment Reminder</strong></p>
                <p class="notif-desc">Dr. Sarah Jenkins • Tomorrow, 10:00 AM</p>
                <span class="notif-time">2h ago</span>
              </div>
            </div>
            <div class="notification-item unread">
              <i class="fa-solid fa-file-medical notif-icon"></i>
              <div class="notif-content">
                <p><strong>New Report Ready</strong></p>
                <p class="notif-desc">Blood Test Results • PDF Available</p>
                <span class="notif-time">5h ago</span>
              </div>
            </div>
            <div class="notification-item">
              <i class="fa-solid fa-prescription notif-icon"></i>
              <div class="notif-content">
                <p><strong>Refill Approved</strong></p>
                <p class="notif-desc">Prescription #1024</p>
                <span class="notif-time">1d ago</span>
              </div>
            </div>
          </div>
          <div class="dropdown-footer">
            <a href="/notifications">View All</a>
          </div>
        </div>
      </div>

      <!-- Profile Dropdown with Logout option -->
      <div class="nav-profile">
        <button
          class="profile-btn"
          id="profileToggle"
          aria-label="User menu"
          aria-expanded="false"
        >
          <!-- ✅ Accept both profilePic AND avatar -->
          <img
            src="<%= user?.profilePic || user?.avatar || '/uploads/profilePictures/defaultProfilePic.jpg' %>"
            alt="<%= user?.fullName || user?.name || 'User' %>"
            class="profile-avatar"
            onerror="
              this.src = '/uploads/profilePictures/defaultProfilePic.jpg'
            "
          />
          <!-- ✅ Accept both fullName AND name -->
          <span class="profile-name"
            ><%= user?.fullName || user?.name || 'User' %></span
          >
          <i class="fa-solid fa-chevron-down profile-arrow"></i>
        </button>

        <div class="profile-dropdown" id="profileDropdown" hidden>
          <div class="profile-header">
            <!-- ✅ Accept both profilePic AND avatar (LARGE) -->
            <img
              src="<%= user?.profilePic || user?.avatar || '/uploads/profilePictures/defaultProfilePic.jpg' %>"
              alt="<%= user?.fullName || user?.name || 'User' %>"
              class="profile-avatar-lg"
              onerror="
                this.src = '/uploads/profilePictures/defaultProfilePic.jpg'
              "
            />
            <div>
              <!-- ✅ Accept both fullName AND name -->
              <p class="profile-fullname">
                <%= user?.fullName || user?.name || 'User' %>
              </p>
              <p class="profile-email">
                <%= user?.email || 'user@example.com' %>
              </p>
            </div>
          </div>

          <ul class="profile-links">
            <li>
              <a href="/profile-settings">
                <i class="fa-regular fa-user"></i> My Profile
              </a>
            </li>
            <li>
              <a href="/others-settings">
                <i class="fa-solid fa-gear"></i> Settings
              </a>
            </li>
            <li>
              <a href="/activity-log">
                <i class="fa-solid fa-shield-halved"></i> Audit & Logs
              </a>
            </li>
            <li><hr /></li>
            <li>
              <form action="/api/auth/logout" method="POST" class="logout-form">
                <button type="submit" class="logout-btn">
                  <i class="fa-solid fa-right-from-bracket"></i> Logout
                </button>
              </form>
            </li>
          </ul>
        </div>
      </div>

      <!-- Mobile Menu Toggle -->
      <button
        class="mobile-menu-btn"
        id="mobileMenuToggle"
        aria-label="Toggle menu"
      >
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
  </div>
</header>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - NovaLife Medical Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <link rel="stylesheet" href="/styles/signup.css" />
  </head>
  <body>
    <!-- ===== LEFT BRAND PANEL ===== -->
    <aside class="brand-panel">
      <div class="brand-content">
        <div class="brand-logo">
          <i class="fa-solid fa-heart-pulse"></i>
        </div>
        <h2 class="brand-name">NovaLife</h2>
        <p class="brand-tagline">
          Your complete digital healthcare companion — secure, simple, and
          always with you.
        </p>

        <ul class="brand-features">
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"
                />
              </svg>
            </div>
            HIPAA-compliant data encryption
          </li>
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"
                />
              </svg>
            </div>
            Personalized health profiles
          </li>
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
                />
              </svg>
            </div>
            24/7 appointment scheduling
          </li>
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z"
                />
              </svg>
            </div>
            Direct messaging with providers
          </li>
        </ul>
      </div>
    </aside>

    <!-- ===== RIGHT FORM PANEL ===== -->
    <main class="form-panel">
      <div class="form-container">
        <!-- Header -->
        <div class="form-header">
          <h1>Reset Your Password</h1>
          <p>Create a new secure password for your account</p>
        </div>

        <!-- Form Card -->
        <div class="form-card">
          <!-- Reset Password Form -->
          <form
            id="resetPasswordForm"
            class="login-form"
            autocomplete="off"
            novalidate
          >
            <div
              class="section-title"
              style="
                margin-bottom: 28px;
                border-bottom: none;
                padding-bottom: 0;
              "
            >
              <div class="section-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                  />
                </svg>
              </div>
              <div>
                <h2>Create New Password</h2>
                <span
                  >Your new password must be different from previous
                  passwords</span
                >
              </div>
            </div>

            <!-- Hidden token input -->
            <input type="hidden" id="resetToken" name="token" />

            <!-- New Password -->
            <div class="form-row full">
              <div class="input-group">
                <label>New Password <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input
                    type="password"
                    id="newPassword"
                    placeholder="Create a strong password"
                    minlength="8"
                    maxlength="32"
                    required
                    oninput="checkPasswordStrength(this.value)"
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                    />
                  </svg>
                  <button
                    class="password-toggle"
                    type="button"
                    onclick="togglePassword('newPassword', this)"
                  >
                    <svg viewBox="0 0 24 24" class="eye-icon">
                      <path
                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                      />
                    </svg>
                  </button>
                </div>
                <!-- Requirement Checklist -->
                <div class="password-requirements">
                  <span class="req-item" id="req-length">8-32 characters</span>
                  <span class="req-item" id="req-upper">Uppercase letter</span>
                  <span class="req-item" id="req-lower">Lowercase letter</span>
                  <span class="req-item" id="req-number">Number</span>
                  <span class="req-item" id="req-special"
                    >Special character</span
                  >
                </div>
                <div class="password-strength" id="passwordStrength">
                  <div class="strength-bars">
                    <div class="strength-bar" id="bar1"></div>
                    <div class="strength-bar" id="bar2"></div>
                    <div class="strength-bar" id="bar3"></div>
                    <div class="strength-bar" id="bar4"></div>
                  </div>
                  <span class="strength-text" id="strengthText"></span>
                </div>
                <span
                  class="error-message"
                  id="newPasswordError"
                  style="
                    display: none;
                    color: var(--error);
                    font-size: 0.8rem;
                    margin-top: 8px;
                  "
                ></span>
              </div>
            </div>

            <!-- Confirm Password -->
            <div class="form-row full">
              <div class="input-group">
                <label
                  >Confirm New Password <span class="required">*</span></label
                >
                <div class="input-wrapper">
                  <input
                    type="password"
                    id="confirmPassword"
                    placeholder="Confirm your new password"
                    minlength="8"
                    maxlength="32"
                    required
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                    />
                  </svg>
                  <button
                    class="password-toggle"
                    type="button"
                    onclick="togglePassword('confirmPassword', this)"
                  >
                    <svg viewBox="0 0 24 24" class="eye-icon">
                      <path
                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                      />
                    </svg>
                  </button>
                </div>
                <span
                  class="error-message"
                  id="confirmPasswordError"
                  style="
                    display: none;
                    color: var(--error);
                    font-size: 0.8rem;
                    margin-top: 8px;
                  "
                ></span>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="form-actions" style="margin-top: 32px">
              <div></div>
              <button type="submit" class="btn btn-primary" id="resetSubmitBtn">
                <span class="btn-text">Reset Password</span>
                <span class="btn-loader" style="display: none">
                  <i class="fa-solid fa-circle-notch fa-spin"></i> Resetting...
                </span>
              </button>
            </div>
          </form>

          <!-- Success Message (Hidden by default) -->
          <div
            id="resetSuccessMessage"
            class="success-message"
            style="display: none; text-align: center; padding: 40px 20px"
          >
            <div class="success-check" style="margin: 0 auto 24px">
              <svg viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
              </svg>
            </div>
            <h2
              style="
                font-family: &quot;Playfair Display&quot;, serif;
                font-size: 1.8rem;
                color: var(--text-dark);
                margin-bottom: 8px;
              "
            >
              Password Reset Successful!
            </h2>
            <p
              style="
                color: var(--text-light);
                font-size: 0.95rem;
                max-width: 360px;
                margin: 0 auto 32px;
                line-height: 1.6;
              "
            >
              Your password has been updated successfully. You can now sign in
              with your new password.
            </p>
            <a
              href="/login"
              class="btn btn-primary btn-full"
              style="max-width: 300px; margin: 0 auto"
            >
              Go to Login
            </a>
          </div>

          <!-- Error Message (Hidden by default) -->
          <div
            id="resetErrorMessage"
            style="
              display: none;
              text-align: center;
              padding: 40px 20px;
              background: var(--error-bg);
              border-radius: var(--radius-md);
              margin-top: 20px;
              border-left: 4px solid var(--error);
            "
          >
            <div
              style="
                width: 60px;
                height: 60px;
                border-radius: 50%;
                background: var(--error);
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 16px;
              "
            >
              <svg
                viewBox="0 0 24 24"
                style="width: 30px; height: 30px; fill: #fff"
              >
                <path
                  d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"
                />
              </svg>
            </div>
            <h3 style="color: var(--error); margin-bottom: 8px">
              Reset Failed
            </h3>
            <p
              id="resetErrorText"
              style="
                color: var(--text-mid);
                font-size: 0.9rem;
                margin-bottom: 20px;
              "
            ></p>
            <a href="/login" class="btn btn-secondary">Return to Login</a>
          </div>
        </div>

        <!-- Back to Login Link -->
        <div style="text-align: center; margin-top: 24px">
          <a
            href="/login"
            style="
              color: var(--primary);
              text-decoration: none;
              font-weight: 500;
              font-size: 0.9rem;
            "
          >
            <i class="fa-solid fa-arrow-left" style="margin-right: 6px"></i>
            Back to Login
          </a>
        </div>
      </div>
    </main>

    <!-- TOAST CONTAINER (BOTTOM-RIGHT) -->
    <div class="toast-container" id="toastContainer"></div>


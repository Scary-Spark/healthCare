<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up - NovaLife Medical Center</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <link rel="stylesheet" href="/styles/signup.css" />
  </head>
  <body>
    <!-- ===== LEFT BRAND PANEL ===== -->
    <aside class="brand-panel">
      <div class="brand-content">
        <div class="brand-logo">
          <i class="fa-solid fa-heart-pulse"></i>
        </div>
        <h2 class="brand-name">NovaLife</h2>
        <p class="brand-tagline">
          Your complete digital healthcare companion — secure, simple, and
          always with you.
        </p>

        <ul class="brand-features">
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"
                />
              </svg>
            </div>
            HIPAA-compliant data encryption
          </li>
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"
                />
              </svg>
            </div>
            Personalized health profiles
          </li>
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
                />
              </svg>
            </div>
            24/7 appointment scheduling
          </li>
          <li>
            <div class="feature-icon">
              <svg viewBox="0 0 24 24">
                <path
                  d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z"
                />
              </svg>
            </div>
            Direct messaging with providers
          </li>
        </ul>
      </div>
    </aside>

    <!-- ===== RIGHT FORM PANEL ===== -->
    <main class="form-panel">
      <div class="form-container">
        <!-- Header -->
        <div class="form-header">
          <h1>Create your account</h1>
          <p>Already have an account? <a href="/login">Sign in</a></p>
        </div>

        <!-- Stepper -->
        <div class="stepper">
          <div class="step active" data-step="1">
            <div class="step-number">1</div>
            <span class="step-label">Personal</span>
          </div>
          <div class="step-line"></div>
          <div class="step" data-step="2">
            <div class="step-number">2</div>
            <span class="step-label">Contact</span>
          </div>
          <div class="step-line"></div>
          <div class="step" data-step="3">
            <div class="step-number">3</div>
            <span class="step-label">Account</span>
          </div>
          <div class="step-line"></div>
          <div class="step" data-step="4">
            <div class="step-number">4</div>
            <span class="step-label">Verify</span>
          </div>
        </div>

        <!-- Form Card -->
        <div class="form-card">
          <!-- Social Sign Up -->
          <div class="social-buttons">
            <button class="btn-social" type="button">
              <svg viewBox="0 0 24 24">
                <path
                  fill="#4285F4"
                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                />
                <path
                  fill="#34A853"
                  d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                />
                <path
                  fill="#FBBC05"
                  d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                />
                <path
                  fill="#EA4335"
                  d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                />
              </svg>
              Google
            </button>
            <button class="btn-social" type="button">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  fill="#1877F2"
                  d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.315 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                />
              </svg>
              Facebook
            </button>
          </div>

          <div class="divider"><span>or</span></div>

          <!-- STEP 1: Personal Info -->
          <div class="form-section active" id="step1">
            <div class="section-title">
              <div class="section-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                  />
                </svg>
              </div>
              <div>
                <h2>Personal Information</h2>
                <span>Let's start with the basics about you</span>
              </div>
            </div>

            <div class="form-row">
              <div class="input-group">
                <label>First Name <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input
                    type="text"
                    id="firstName"
                    placeholder="John"
                    required
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                    />
                  </svg>
                </div>
              </div>
              <div class="input-group">
                <label>Last Name <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input type="text" id="lastName" placeholder="Doe" required />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                    />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-row">
              <div class="input-group">
                <label>Date of Birth <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input type="date" id="dob" required />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"
                    />
                  </svg>
                </div>
              </div>
              <div class="input-group">
                <label>Gender</label>
                <div class="input-wrapper">
                  <select id="gender">
                    <option value="" disabled selected>Select gender</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                    <!-- <option value="prefer-not">Prefer not to say</option> -->
                  </select>
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                    />
                  </svg>
                  <svg class="select-arrow" viewBox="0 0 24 24">
                    <path d="M7 10l5 5 5-5z" />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-row full">
              <div class="input-group">
                <label>Blood Group</label>
                <div class="input-wrapper">
                  <select id="bloodGroup">
                    <option value="" disabled selected>
                      Select blood group
                    </option>
                    <option value="A+">A+</option>
                    <option value="A-">A−</option>
                    <option value="B+">B+</option>
                    <option value="B-">B−</option>
                    <option value="AB+">AB+</option>
                    <option value="AB-">AB−</option>
                    <option value="O+">O+</option>
                    <option value="O-">O−</option>
                    <option value="not-tested">Not Tested</option>
                  </select>
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
                    />
                  </svg>
                  <svg class="select-arrow" viewBox="0 0 24 24">
                    <path d="M7 10l5 5 5-5z" />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-actions">
              <div></div>
              <button class="btn btn-primary" onclick="nextStep(2)">
                Continue
                <svg viewBox="0 0 24 24">
                  <path
                    d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"
                  />
                </svg>
              </button>
            </div>
          </div>

          <!-- STEP 2: Contact Info -->
          <div class="form-section" id="step2">
            <div class="section-title">
              <div class="section-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                  />
                </svg>
              </div>
              <div>
                <h2>Contact Information</h2>
                <span>How can we reach you?</span>
              </div>
            </div>

            <div class="form-row full">
              <div class="input-group">
                <label>Email Address <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input
                    type="email"
                    id="email"
                    placeholder="john.doe@email.com"
                    required
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                    />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-row full">
              <div class="input-group">
                <label>Phone Number <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input
                    type="tel"
                    id="phone"
                    placeholder="+880 1234567890"
                    required
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                    />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-row full">
              <div class="input-group">
                <label>Address</label>
                <div class="input-wrapper">
                  <input
                    type="text"
                    id="address"
                    placeholder="123 Health Street, City, State"
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                    />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-row">
              <div class="input-group">
                <label>City</label>
                <div class="input-wrapper">
                  <input type="text" id="city" placeholder="Rajshahi" />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M15 11V5l-3-3-3 3v2H3v14h18V11h-6zm-8 8H5v-2h2v2zm0-4H5v-2h2v2zm0-4H5V9h2v2zm6 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2zm0-4h-2V5h2v2zm6 12h-2v-2h2v2zm0-4h-2v-2h2v2z"
                    />
                  </svg>
                </div>
              </div>
              <div class="input-group">
                <label>Postal Code</label>
                <div class="input-wrapper">
                  <input type="text" id="zip" placeholder="6000" />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M15 11V5l-3-3-3 3v2H3v14h18V11h-6zm-8 8H5v-2h2v2zm0-4H5v-2h2v2zm0-4H5V9h2v2zm6 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V9h2v2zm0-4h-2V5h2v2zm6 12h-2v-2h2v2zm0-4h-2v-2h2v2z"
                    />
                  </svg>
                </div>
              </div>
            </div>

            <div class="form-actions">
              <button class="btn btn-secondary" onclick="prevStep(1)">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                  />
                </svg>
                Back
              </button>
              <button class="btn btn-primary" onclick="nextStep(3)">
                Continue
                <svg viewBox="0 0 24 24">
                  <path
                    d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"
                  />
                </svg>
              </button>
            </div>
          </div>

          <!-- STEP 3: Account Setup -->
          <div class="form-section" id="step3">
            <div class="section-title">
              <div class="section-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                  />
                </svg>
              </div>
              <div>
                <h2>Account Setup</h2>
                <span>Secure your account with a strong password</span>
              </div>
            </div>

            <div class="form-row full">
              <div class="input-group">
                <label>Password <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input
                    type="password"
                    id="password"
                    placeholder="Create a strong password"
                    required
                    oninput="checkPasswordStrength(this.value)"
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                    />
                  </svg>
                  <button
                    class="password-toggle"
                    type="button"
                    onclick="togglePassword('password', this)"
                  >
                    <svg viewBox="0 0 24 24" class="eye-icon">
                      <path
                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                      />
                    </svg>
                  </button>
                </div>
                <div class="password-strength" id="passwordStrength">
                  <div class="strength-bars">
                    <div class="strength-bar" id="bar1"></div>
                    <div class="strength-bar" id="bar2"></div>
                    <div class="strength-bar" id="bar3"></div>
                    <div class="strength-bar" id="bar4"></div>
                  </div>
                  <span class="strength-text" id="strengthText"></span>
                </div>
              </div>
            </div>

            <div class="form-row full">
              <div class="input-group">
                <label>Confirm Password <span class="required">*</span></label>
                <div class="input-wrapper">
                  <input
                    type="password"
                    id="confirmPassword"
                    placeholder="Confirm your password"
                    required
                  />
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"
                    />
                  </svg>
                  <button
                    class="password-toggle"
                    type="button"
                    onclick="togglePassword('confirmPassword', this)"
                  >
                    <svg viewBox="0 0 24 24" class="eye-icon">
                      <path
                        d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                      />
                    </svg>
                  </button>
                </div>
              </div>
            </div>

            <div class="checkbox-group">
              <input type="checkbox" id="terms" />
              <label class="custom-checkbox" for="terms">
                <svg viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
              </label>
              <label class="checkbox-label" for="terms">
                I agree to the <a href="#">Terms of Service</a> and
                <a href="#">Privacy Policy</a>
              </label>
            </div>

            <div class="checkbox-group">
              <input type="checkbox" id="newsletter" />
              <label class="custom-checkbox" for="newsletter">
                <svg viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
              </label>
              <label class="checkbox-label" for="newsletter">
                Send me health tips & updates (optional)
              </label>
            </div>

            <div class="form-actions">
              <button class="btn btn-secondary" onclick="prevStep(2)">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                  />
                </svg>
                Back
              </button>
              <button class="btn btn-primary" onclick="nextStep(4)">
                Continue
                <svg viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
              </button>
            </div>
          </div>

          <!-- STEP 4: Verification -->
          <div class="form-section" id="step4">
            <div class="section-title">
              <div class="section-icon">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"
                  />
                </svg>
              </div>
              <div>
                <h2>Verify Your Account</h2>
                <span>Secure your account with email & phone verification</span>
              </div>
            </div>

            <!-- Email Verification Card -->
            <div class="verify-card" id="emailVerifyCard">
              <div class="verify-header">
                <div class="verify-icon email">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                    />
                  </svg>
                </div>
                <div class="verify-info">
                  <h4>Email Verification</h4>
                  <p id="emailDisplay">john.doe@email.com</p>
                </div>
                <span class="verify-status" id="emailStatus">Pending</span>
              </div>

              <div class="verify-actions">
                <button
                  class="btn btn-secondary btn-sm"
                  id="sendEmailCode"
                  onclick="sendVerificationCode('email')"
                >
                  <span class="btn-text">Send Code</span>
                  <span class="btn-loader" style="display: none">
                    <i class="fa-solid fa-circle-notch fa-spin"></i> Sending...
                  </span>
                </button>
                <span class="resend-timer" id="emailTimer" style="display: none"
                  >Resend in <strong>30s</strong></span
                >
              </div>

              <div
                class="otp-input-group"
                id="emailOtpGroup"
                style="display: none"
              >
                <p class="otp-instruction">
                  Enter the 6-digit code sent to your email
                </p>
                <div class="otp-inputs">
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="email"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="email"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="email"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="email"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="email"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="email"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                </div>
                <div class="otp-actions">
                  <button
                    class="btn btn-primary btn-sm"
                    onclick="verifyCode('email')"
                  >
                    Verify Email
                  </button>
                  <a href="#" class="otp-resend" onclick="resendCode('email')"
                    >Resend code</a
                  >
                </div>
                <span class="error-message" id="emailOtpError"></span>
              </div>

              <div
                class="verify-success"
                id="emailSuccess"
                style="display: none"
              >
                <svg viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
                <span>Email verified successfully!</span>
              </div>
            </div>

            <!-- Phone Verification Card -->
            <div class="verify-card" id="phoneVerifyCard">
              <div class="verify-header">
                <div class="verify-icon phone">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                    />
                  </svg>
                </div>
                <div class="verify-info">
                  <h4>Phone Verification</h4>
                  <p id="phoneDisplay">+880 1234567890</p>
                </div>
                <span class="verify-status" id="phoneStatus">Pending</span>
              </div>

              <div class="verify-actions">
                <button
                  class="btn btn-secondary btn-sm"
                  id="sendPhoneCode"
                  onclick="sendVerificationCode('phone')"
                >
                  <span class="btn-text">Send Code</span>
                  <span class="btn-loader" style="display: none">
                    <i class="fa-solid fa-circle-notch fa-spin"></i> Sending...
                  </span>
                </button>
                <span class="resend-timer" id="phoneTimer" style="display: none"
                  >Resend in <strong>30s</strong></span
                >
              </div>

              <div
                class="otp-input-group"
                id="phoneOtpGroup"
                style="display: none"
              >
                <p class="otp-instruction">
                  Enter the 6-digit code sent to your phone
                </p>
                <div class="otp-inputs">
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="phone"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="phone"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="phone"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="phone"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="phone"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                  <input
                    type="text"
                    maxlength="1"
                    class="otp-digit"
                    data-target="phone"
                    inputmode="numeric"
                    pattern="[0-9]*"
                  />
                </div>
                <div class="otp-actions">
                  <button
                    class="btn btn-primary btn-sm"
                    onclick="verifyCode('phone')"
                  >
                    Verify Phone
                  </button>
                  <a href="#" class="otp-resend" onclick="resendCode('phone')"
                    >Resend code</a
                  >
                </div>
                <span class="error-message" id="phoneOtpError"></span>
              </div>

              <div
                class="verify-success"
                id="phoneSuccess"
                style="display: none"
              >
                <svg viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
                <span>Phone verified successfully!</span>
              </div>
            </div>

            <!-- Skip Option -->
            <div class="verify-skip">
              <label class="checkbox-wrapper">
                <input type="checkbox" id="skipVerification" />
                <span class="checkmark"></span>
                <span class="skip-label"
                  >Skip verification for now (not recommended)</span
                >
              </label>
            </div>

            <div class="form-actions">
              <button class="btn btn-secondary" onclick="prevStep(3)">
                <svg viewBox="0 0 24 24">
                  <path
                    d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"
                  />
                </svg>
                Back
              </button>
              <button class="btn btn-primary" onclick="completeSignup()">
                Complete Registration
                <svg viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- ===== SUCCESS OVERLAY ===== -->
    <div class="success-overlay" id="successOverlay">
      <div class="success-card">
        <div class="success-check">
          <svg viewBox="0 0 24 24">
            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
          </svg>
        </div>
        <h2>Welcome to NovaLife! 🎉</h2>
        <p>
          Your NovaLife account has been created successfully. You're all set to
          take control of your health.
        </p>
        <button
          class="btn btn-primary btn-full"
          onclick="closeSuccess()"
          style="max-width: 300px; margin: 0 auto"
        >
          Get Started
        </button>
      </div>
    </div>

    <!-- ===== TOAST ===== -->
    <div class="toast" id="toast">
      <div class="toast-icon">
        <svg viewBox="0 0 24 24">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" />
        </svg>
      </div>
      <div class="toast-content">
        <h4>Step completed!</h4>
        <p id="toastMessage">Personal info saved.</p>
      </div>
    </div>

    <script src="/scripts/signup.js"></script>
  </body>
</html>
